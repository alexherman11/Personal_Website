ANTHROPIC_API_KEY=sk-ant-...
PORT=3001
CORS_ORIGIN=http://localhost:5173

# Required to enable /private flyer-submission viewer.
# Without these set, /private returns 503.
PRIVATE_ADMIN_USER=
PRIVATE_ADMIN_PASSWORD=

# Required to enable the Foreman private console proxy.
# The token is never sent to the browser.
FOREMAN_API_BASE=https://foreman.agoraserver.com
FOREMAN_MCP_TOKEN=
FOREMAN_DEFAULT_REPO_HINT=/mnt/c/Projects/Anima
